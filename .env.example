# ============================================================
# Jan Awaaz AI — Root environment file for docker-compose
# Copy this file to .env and fill in your values before running
#   cp .env.example .env
# ============================================================

# --- Frontend (Vite build-time args) ---
# These are baked into the frontend bundle at build time.
# Get them from: Firebase Console > Project Settings > Your apps > Web

VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
