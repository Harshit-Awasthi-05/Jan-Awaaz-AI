#

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Path to your Firebase/GCP service account JSON (used for Firebase Admin,
# Firestore, and BigQuery). Never commit the actual JSON file.
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# Only needed if you're tunneling the local backend for demo purposes
NGROK_AUTHTOKEN=

# Used to sign MP JWT access tokens. Generate a real random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# GCP project id (for BigQuery) and Firebase project id (for Auth/Firestore)
GCP_PROJECT_ID=
FIREBASE_PROJECT_ID=jan-awaaz-ai-authentication



# Cloudinary (media storage for citizen-uploaded photos/videos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Comma-separated list of allowed CORS origins for production, e.g.:
#   https://your-frontend.vercel.app,https://janawaaz.in
# Leave as * only for local development.
ALLOWED_HOSTS=*