

# Backend API base URL. Point this at your deployed backend for production
# builds; leave as localhost for local dev against `uvicorn` running on 8000.
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Firebase Web SDK config (from Firebase Console > Project Settings > General
# > Your apps > Web app). These are safe to expose in client code, but keep
# them in .env for cleanliness and easy swapping between environments.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=